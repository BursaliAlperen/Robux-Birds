# Put the Firebase service account JSON here as a single-line JSON string or base64 JSON.
# Example: FIREBASE_CREDENTIALS={"type":"service_account","project_id":"..."}
FIREBASE_CREDENTIALS={}
PORT=3000
# Comma-separated lowercase game user IDs that may use /api/admin/* endpoints.
ADMIN_USER_IDS=
# Optional: set to your Render public URL (for example https://robux-birds.onrender.com) to self-ping /health.
KEEP_ALIVE_URL=
KEEP_ALIVE_INTERVAL_MS=840000
